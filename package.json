{
  "name": "casa-barbato",
  "version": "1.0.0",
  "description": "Dashboard per domotica Bticino",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "app": "vite build && electron .",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.casabarbato.dashboard",
    "productName": "Casa Barbato",
    "directories": {
      "output": "dist-mac"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "files": [
      "dist/**/*",
      "main.js",
      "server.js",
      "package.json",
      "node_modules/**/*",
      ".env"
    ]
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.3.1"
  }
}
